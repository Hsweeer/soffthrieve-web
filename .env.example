# Optional: replace with your rebranded Spline robot scene URL from spline.design
NEXT_PUBLIC_SPLINE_ROBOT_SCENE=https://prod.spline.design/kZDDjO5HuCqvCqkL/scene.splinecode

# Footer social links (optional — defaults to SoftThrive profiles / WhatsApp compose)
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_UPWORK_URL=
NEXT_PUBLIC_FIVERR_URL=
# Required for wa.me links (digits only, e.g. 923001234567 for +92 300 1234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=923114388760
# Optional full URL — if set without a number path, NEXT_PUBLIC_WHATSAPP_NUMBER is used instead
NEXT_PUBLIC_WHATSAPP_URL=

# --- Chat assistant (free tier — pick one or both; keys stay server-side only) ---
# Groq: https://console.groq.com/keys — free Llama models, fast
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini: https://aistudio.google.com/apikey — free Flash tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
